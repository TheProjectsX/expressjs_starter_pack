{
    "name": "expressjs-starter-pack",
    "version": "2.0.0",
    "description": "Starter pack for Express JS backend project",
    "main": "server.js",
    "type": "commonjs",
    "keywords": [],
    "author": "TheProjectsX",
    "license": "ISC",
    "scripts": {
        "start": "node -r tsconfig-paths/register dist/server.js",
        "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
        "build": "tsc && tsc-alias",
        "cModule": "node scripts/generateModule.mjs",
        "postinstall": "npx prisma generate",
        "check": "eslint src && npx prettier --write src && npm run build && echo [✓] All checks passed!"
    },
    "dependencies": {
        "@prisma/client": "^6.15.0",
        "@sendgrid/mail": "^8.1.5",
        "@types/jsonwebtoken": "^9.0.10",
        "axios": "^1.11.0",
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^17.2.1",
        "express": "^5.1.0",
        "http-status-codes": "^2.3.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "2.0.2",
        "nanoid": "^3.3.8",
        "node-cron": "^4.2.1",
        "nodemailer": "^7.0.6",
        "stripe": "^19.1.0",
        "tsconfig-paths": "^4.2.0",
        "zod": "^4.1.5"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.9",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.3",
        "@types/multer": "^2.0.0",
        "@types/node": "^24.3.0",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^7.0.1",
        "eslint": "^9.39.1",
        "prisma": "^6.15.0",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "tsc-alias": "^1.8.16",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.48.0"
    }
}
